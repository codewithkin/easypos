{
  "expo": {
    "name": "EasyPOS",
    "slug": "easypos",
    "scheme": "easypos",
    "version": "1.0.0",
    "assetBundlePatterns": [
      "**/*"
    ],
    "userInterfaceStyle": "automatic",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "c68ec085-d12c-4ac8-acd6-7b025900cd91"
      }
    },
    "owner": "codewithkin",
    "android": {
      "package": "com.christusveritastechnologies.easypos"
    }
  }
}
