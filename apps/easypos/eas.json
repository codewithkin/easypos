{
  "cli": {
    "version": ">= 18.0.6",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_USE_FAST_RESOLVER": "true"
      },
      "node": "20.19.0",
      "resourceClass": "default"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_USE_FAST_RESOLVER": "true"
      },
      "node": "20.19.0",
      "resourceClass": "default"
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_USE_FAST_RESOLVER": "true"
      },
      "node": "20.19.0",
      "resourceClass": "default"
    }
  },
  "submit": {
    "production": {}
  }
}
