DATABASE_URL=postgresql://user:password@localhost:5432/easypos
CORS_ORIGIN=http://localhost:8081
NODE_ENV=development
JWT_SECRET=change-me-to-a-secure-random-string-in-production
JWT_REFRESH_SECRET=change-me-to-another-secure-random-string

# SMTP — use Mailtrap for dev, Postmark/Resend/SES for production
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
SMTP_FROM=EasyPOS <noreply@easypos.app>
APP_URL=http://localhost:8081

# Paynow payment gateway
PAYNOW_INTEGRATION_ID=your_paynow_integration_id
PAYNOW_INTEGRATION_KEY=your_paynow_integration_key
PAYNOW_RESULT_URL=http://localhost:3000/api/billing/webhook
PAYNOW_RETURN_URL=http://localhost:3000/api/billing/confirm

# Cloudflare R2 — create an R2 bucket and API token at dash.cloudflare.com
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=easypos-uploads
R2_PUBLIC_URL=https://pub-xxxx.r2.dev
