generator client {
  provider     = "prisma-client"
  output       = "../generated"
  moduleFormat = "esm"
  runtime      = "bun"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ──────────────────────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  STAFF
}

enum PaymentMethod {
  CASH
  MOBILE_MONEY
  SWIPE
  CREDIT
}

enum SaleStatus {
  COMPLETED
  VOIDED
  REFUNDED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Plan {
  starter
  growth
  enterprise
}

// ── Organization (Tenant) ──────────────────────────────────────────

model Organization {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  currency      String   @default("UGX")
  logoUrl       String?
  receiptHeader String?
  receiptFooter String?

  // ── Subscription & Billing ─────────────────────────────────────
  plan                        Plan     @default(starter)
  maxUsers                    Int      @default(5)
  maxMonthlyInvoices          Int      @default(1000)
  maxProducts                 Int      @default(300)
  maxCategories               Int      @default(50)
  maxBranches                 Int      @default(1)
  currentMonthInvoices        Int      @default(0)
  currentMonthOverageInvoices Int      @default(0)
  currentMonthOverageProducts Int      @default(0)
  currentMonthOverageCategories Int    @default(0)
  pendingOverageCharges       Float    @default(0)
  billingCycleStart           DateTime @default(now())
  nextBillingDate             DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches             Branch[]
  users                User[]
  categories           Category[]
  products             Product[]
  sales                Sale[]
  customers            Customer[]
  tags                 Tag[]
  auditLogs            AuditLog[]
  intermediatePayments IntermediatePayment[]
}

// ── Branch / Location ──────────────────────────────────────────────

model Branch {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  isActive  Boolean  @default(true)
  orgId     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  users   User[]
  devices Device[]
  sales   Sale[]

  @@index([orgId])
}

// ── User ───────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  pin          String?
  role         Role     @default(STAFF)
  isActive     Boolean  @default(true)
  orgId        String
  branchId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  org            Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch         Branch?         @relation(fields: [branchId], references: [id])
  sales          Sale[]          @relation("CashierSales")
  refreshTokens  RefreshToken[]
  passwordResets PasswordReset[]
  auditLogs      AuditLog[]
  intermediatePayments IntermediatePayment[]

  @@index([orgId])
  @@index([branchId])
}

// ── Auth ───────────────────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model PasswordReset {
  id        String    @id @default(cuid())
  code      String
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([code])
}

// ── Device / Register ──────────────────────────────────────────────

model Device {
  id               String    @id @default(cuid())
  name             String
  deviceIdentifier String
  branchId         String
  lastSeenAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  sales  Sale[]

  @@unique([deviceIdentifier, branchId])
  @@index([branchId])
}

// ── Catalog ────────────────────────────────────────────────────────

model Category {
  id        String   @id @default(cuid())
  name      String
  orgId     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  products Product[]

  @@index([orgId])
}

model Product {
  id         String   @id @default(cuid())
  name       String
  sku        String
  imageUrl   String?
  price      Float
  cost       Float?
  stock      Int      @default(0)
  isActive   Boolean  @default(true)
  categoryId String?
  orgId      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category  Category?    @relation(fields: [categoryId], references: [id])
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  saleItems SaleItem[]
  tags      ProductTag[]

  @@unique([sku, orgId])
  @@index([orgId])
  @@index([categoryId])
}

// ── Product Tags ───────────────────────────────────────────────────

model Tag {
  id        String   @id @default(cuid())
  name      String
  orgId     String
  createdAt DateTime @default(now())

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  products ProductTag[]

  @@unique([name, orgId])
  @@index([orgId])
}

model ProductTag {
  productId String
  tagId     String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@index([tagId])
}

// ── Sales Ledger ───────────────────────────────────────────────────

model Sale {
  id            String        @id @default(cuid())
  receiptNumber String
  subtotal      Float
  discount      Float         @default(0)
  tax           Float         @default(0)
  total         Float
  amountTendered Float?
  change        Float?
  paymentMethod PaymentMethod @default(CASH)
  status        SaleStatus    @default(COMPLETED)
  note          String?
  cashierId     String
  branchId      String
  orgId         String
  deviceId      String?
  customerId    String?
  createdAt     DateTime      @default(now())

  cashier  User         @relation("CashierSales", fields: [cashierId], references: [id])
  branch   Branch       @relation(fields: [branchId], references: [id])
  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  device   Device?      @relation(fields: [deviceId], references: [id])
  customer Customer?    @relation(fields: [customerId], references: [id])
  items    SaleItem[]
  receipts Receipt[]

  @@index([orgId])
  @@index([branchId])
  @@index([cashierId])
  @@index([customerId])
  @@index([createdAt])
}

model SaleItem {
  id          String @id @default(cuid())
  saleId      String
  productId   String
  productName String
  quantity    Int
  unitPrice   Float
  total       Float

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([saleId])
}

// ── Receipts ───────────────────────────────────────────────────────

model Receipt {
  id          String   @id @default(cuid())
  saleId      String
  printedAt   DateTime @default(now())
  printerName String?

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
}

// ── Audit Trail ────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  details   String?
  metadata  Json?
  userId    String
  orgId     String
  createdAt DateTime @default(now())

  user User         @relation(fields: [userId], references: [id])
  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([userId])
  @@index([createdAt])
}

// ── Billing / Payments ─────────────────────────────────────────────

model IntermediatePayment {
  id            String   @id @default(cuid())
  planName      String   // e.g. "starter", "growth", "enterprise"
  amount        Float
  currency      String   @default("USD")
  pollUrl       String?
  paid          Boolean  @default(false)
  failureReason String?
  userId        String
  orgId         String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User         @relation(fields: [userId], references: [id])
  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([userId])
}

// ── Customers ──────────────────────────────────────────────────────

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  gender    Gender?
  notes     String?
  orgId     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sales Sale[]

  @@index([orgId])
  @@index([phone, orgId])
}
